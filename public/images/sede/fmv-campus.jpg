			/*facultad de medicina veterinaria*/
.find-program-warp {
    padding-top: 70px;
}

.ptb-100 {
    padding-top: 30px;
    padding-bottom: 30px;
}

/*css para hacer que el contenedor este mas ancho , a la altura del logo
@media (min-width: 1400px) {
    .container, .container-lg, .container-md, .container-sm, .container-xl, .container-xxl {
        max-width: 1720px;
    }
}*/

.navbar.transparent-bg {
    background-color: transparent;
    box-shadow: rgba(0, 0, 0, 0.15) 1.95px 1.95px 2.6px;
}

/* Media query para aplicar estilos solo en dispositivos móviles (como en tu captura) */
@media (max-width: 991px) {

  /* 1. Hacemos que el contenedor del logo y el menú sea flexible y alinee los ítems */
  .navbar-expand-lg > .container-fluid {
    display: flex;
    justify-content: space-between; /* Alinea un ítem al inicio y otro al final */
    align-items: center; /* Centra los ítems verticalmente */
  }

  /* 2. Reducimos el tamaño del logo */
  .navbar-brand img {
    /* Prueba ajustando este valor. Un 70% o un valor fijo como 250px suele funcionar */
    max-width: 305px !important; 
    height: auto; /* Mantenemos la proporción */
  }

}

/*oculta la imagen destacada en rivep articulos*/
.single-post .blog-image-with-content {
  display: none;
}

/*altuta titulo  pdf*/
#et-boc .wpfd-content-table .wpfd-table-bordered td, .wpfd-content-table .wpfd-table-bordered td {
    line-height: 20px !important;
    border-top: 1px solid #cccccc;
    border-left: 0;
    border-right: 0;
    border-bottom: 0;
}

.inner-heros-warp {
    padding-top: 305px;
    padding-bottom: 50px;
    position: relative;
    background: linear-gradient(90deg, #DDE6F4 0%, #E6EAF8 17.57%, #D4DCFC 34.86%, #E2E6F6 52.23%, #E0E5F8 65.17%, #EEF4FD 97.75%);
    margin-top: -155px;
    display: none !important;
}


.swiper-button-next, .swiper-button-prev {
    position: absolute;
    top: 30%;
    width: calc(var(--swiper-navigation-size) / 44 * 27);
    height: var(--swiper-navigation-size);
    margin-top: calc(0px - (var(--swiper-navigation-size) / 2));
    z-index: 10;
    cursor: pointer;
    display: flex
;
    align-items: center;
    justify-content: center;
    color: var(--swiper-navigation-color, var(--swiper-theme-color));
}

h3{
  line-height: 0.9 !important;
}
/* --- Media Query para dispositivos móviles --- */
@media (max-width: 767px) {
  h3 {
    /* Aquí pones los estilos que quieres cambiar en móviles */
    line-height: 1 !important; /* Un interlineado mayor puede mejorar la legibilidad */
    
  }		</style>
