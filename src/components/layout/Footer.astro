---
import site from '../../data/site.json';
const base = import.meta.env.BASE_URL === '/' ? '/' : import.meta.env.BASE_URL + '/';
---

<footer class="footer footer-bg">
  <!-- Wave Top Divider -->
  <div style="line-height:0; color: #593414;">
    <svg viewBox="0 0 1440 60" fill="currentColor" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" style="width:100%; height:60px; display:block;">
      <path d="M0,40 C360,80 1080,0 1440,40 L1440,60 L0,60 Z"/>
    </svg>
  </div>

  <div class="container footer__inner">
    <!-- Brand Column -->
    <div class="footer__brand">
      <div class="footer__logo">
        <img src={`${base}images/aliados/logo_app.png`} alt="Logo Asociación Peruana de Primatología" width="180" height="auto" style="object-fit: contain; margin-bottom: 1rem;" />
      </div>
      <div class="footer__brand-info">
        <h2 class="footer__title">III CONGRESO PERUANO DE PRIMATOLOGÍA 2026</h2>
        <p class="footer__slogan">{site.slogan}</p>
      </div>
    </div>

    <!-- Navigation Columns -->
    <div class="footer__links">
      <div class="footer__col">
        <h3 class="footer__col-title">Congreso</h3>
        <ul class="footer__col-list">
          <li><a href={`${base}sobre-el-congreso`}>Sobre el Congreso</a></li>
          <li><a href={`${base}programa`}>Programa</a></li>
<!-- <li><a href={`${base}ponentes`}>Ponentes</a></li> -->
          <li><a href={`${base}inscripciones`}>Inscripciones</a></li>
        </ul>
      </div>

      <div class="footer__col">
        <h3 class="footer__col-title">Participar</h3>
        <ul class="footer__col-list">
          <li><a href={`${base}llamado-de-resumenes`}>Enviar resumen</a></li>
          <li><a href={`${base}inscripciones`}>Registrarse</a></li>
          <li><a href={`${base}conservacion`}>Conservación</a></li>
          <li><a href={`${base}noticias`}>Noticias</a></li>
        </ul>
      </div>

      <div class="footer__col">
        <h3 class="footer__col-title">Contacto</h3>
        <ul class="footer__col-list">
          <li>
            <a href={`mailto:${site.contact.email}`}>
              📧 {site.contact.email}
            </a>
          </li>
          <li>📍 Lima, Perú</li>
          <li>📅 {site.dates.event}</li>
        </ul>

        <!-- Social Links -->
        <div class="footer__social">
          <a href={site.contact.instagram} class="footer__social-link" target="_blank" rel="noopener" aria-label="Instagram">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          </a>
          <a href={site.contact.facebook} class="footer__social-link" target="_blank" rel="noopener" aria-label="Facebook">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="footer__bottom">
    <div class="container footer__bottom-inner">
      <div class="footer__copyright">
        <p>© 2026 {site.organizer.name}. Todos los derechos reservados.</p>
        <p>Hecho con ❤️ para la conservación de primates en Perú</p>
      </div>
      <div class="footer__counter" title="Contador de visitas totales">
        <img src="https://komarev.com/ghpvc/?username=primatologiaperu2026&color=D99D55&style=flat-square&label=VISITAS" alt="Contador de visitas" loading="lazy" />
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    color: var(--text-on-dark);
  }

  .footer__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    padding-top: 3rem;
    padding-bottom: 3rem;
  }

  @media (min-width: 768px) {
    .footer__inner {
      grid-template-columns: 1.5fr 2fr;
      gap: 4rem;
    }
  }

  /* Brand */
  .footer__brand {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .footer__logo {
    font-size: 2.5rem;
  }

  .footer__title {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 700;
    line-height: 1.3;
    color: var(--forest-canopy);
    margin-bottom: 0.5rem;
    max-width: 240px;
  }

  .footer__slogan {
    font-family: var(--font-ui);
    font-size: 0.8rem;
    color: rgba(255,255,255,0.45);
    line-height: 1.5;
    max-width: 240px;
  }


  /* Links */
  .footer__links {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 2rem;
  }

  .footer__col-title {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--forest-canopy);
    margin-bottom: 1rem;
  }

  .footer__col-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .footer__col-list li,
  .footer__col-list a {
    font-family: var(--font-body);
    font-size: 0.88rem;
    color: rgba(255,255,255,0.65);
    transition: color var(--transition-fast);
  }

  .footer__col-list a:hover {
    color: var(--forest-canopy);
  }

  /* Social */
  .footer__social {
    display: flex;
    gap: 0.75rem;
    margin-top: 1.25rem;
  }

  .footer__social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: rgba(217, 157, 85, 0.15);
    color: var(--forest-canopy);
    border: 1px solid rgba(217, 157, 85, 0.25);
    transition: all var(--transition-mid);
  }

  .footer__social-link:hover {
    background: var(--forest-mid);
    color: #fff;
    transform: translateY(-2px);
  }

  /* Bottom */
  .footer__bottom {
    border-top: 1px solid rgba(217, 157, 85, 0.15);
  }

  .footer__bottom-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    padding: 1.5rem 0;
    text-align: center;
  }

  @media (min-width: 640px) {
    .footer__bottom-inner {
      flex-direction: row;
      justify-content: space-between;
      text-align: left;
    }
  }

  .footer__copyright {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .footer__bottom p {
    font-family: var(--font-ui);
    font-size: 0.78rem;
    color: rgba(255,255,255,0.4);
  }

  .footer__counter {
    opacity: 0.8;
    transition: opacity var(--transition-fast);
  }
  .footer__counter:hover {
    opacity: 1;
  }
</style>
