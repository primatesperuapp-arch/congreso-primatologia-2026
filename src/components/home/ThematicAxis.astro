---
import axes from '../../data/thematic-axes.json';
---

<section class="section thematic" id="ejes">
  <div class="container">
    <div class="section-header reveal">
      <span class="section-label">Áreas de investigación</span>
      <h2 class="section-title">Ejes Temáticos</h2>
      <p class="section-subtitle">
        El congreso reúne la investigación primatológica en seis grandes áreas interdisciplinarias, abordando desde la genética molecular hasta la educación ambiental comunitaria.
      </p>
    </div>

    <div class="thematic__grid">
      {axes.map((axis, i) => (
        <article
          class={`axis-card reveal reveal-delay-${(i % 3) + 1}`}
          style={`--axis-color: ${axis.color};`}
          tabindex="0"
          role="button"
          aria-expanded="false"
        >
          <div class="axis-card__header">
            <div class="axis-card__emoji" aria-hidden="true">{axis.emoji}</div>
            <div class="axis-card__code">
              <span class="badge" style={`background: ${axis.color}20; color: ${axis.color}; border: 1px solid ${axis.color}40;`}>
                {axis.code}
              </span>
            </div>
          </div>

          <h3 class="axis-card__title">{axis.title}</h3>
          <p class="axis-card__desc">{axis.description}</p>

          <div class="axis-card__topics">
            {axis.subtopics.map(topic => (
              <span class="axis-card__topic">{topic}</span>
            ))}
          </div>

          <div class="axis-card__glow" aria-hidden="true"></div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .thematic {
    background: linear-gradient(180deg, var(--cream-warm) 0%, var(--cream) 100%);
  }

  :global([data-theme="dark"]) .thematic {
    background: linear-gradient(180deg, #41240e 0%, #593414 100%);
  }

  .thematic__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 640px) {
    .thematic__grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 1024px) {
    .thematic__grid { grid-template-columns: repeat(3, 1fr); }
  }

  .axis-card {
    position: relative;
    padding: 2rem;
    background: rgba(255,255,255,0.9);
    border-radius: var(--radius-lg);
    border: 1.5px solid transparent;
    box-shadow: var(--shadow-sm);
    cursor: pointer;
    transition: all var(--transition-mid);
    overflow: hidden;
  }

  :global([data-theme="dark"]) .axis-card {
    background: rgba(15, 41, 32, 0.7);
    border-color: rgba(82,183,136,0.1);
  }

  .axis-card:hover,
  .axis-card:focus {
    border-color: var(--axis-color);
    transform: translateY(-5px);
    box-shadow: var(--shadow-md), 0 0 30px color-mix(in srgb, var(--axis-color) 15%, transparent);
    outline: none;
  }

  .axis-card__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 1.25rem;
  }

  .axis-card__emoji {
    font-size: 2.5rem;
    line-height: 1;
  }

  .axis-card__title {
    font-family: var(--font-body);
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--text-on-light);
    margin-bottom: 0.75rem;
    line-height: 1.3;
  }

  :global([data-theme="dark"]) .axis-card__title {
    color: var(--text-on-dark);
  }

  .axis-card__desc {
    font-size: 0.865rem;
    color: var(--text-muted);
    line-height: 1.65;
    margin-bottom: 1.25rem;
  }

  .axis-card__topics {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .axis-card__topic {
    font-family: var(--font-ui);
    font-size: 0.7rem;
    font-weight: 600;
    padding: 0.25rem 0.65rem;
    background: color-mix(in srgb, var(--axis-color) 10%, transparent);
    color: var(--axis-color);
    border-radius: 100px;
    border: 1px solid color-mix(in srgb, var(--axis-color) 25%, transparent);
  }

  .axis-card__glow {
    position: absolute;
    bottom: -40px;
    right: -40px;
    width: 120px;
    height: 120px;
    border-radius: 50%;
    background: radial-gradient(circle, color-mix(in srgb, var(--axis-color) 20%, transparent), transparent 70%);
    transition: opacity var(--transition-mid);
    opacity: 0;
    pointer-events: none;
  }

  .axis-card:hover .axis-card__glow {
    opacity: 1;
  }
</style>
