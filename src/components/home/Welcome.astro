---
import site from '../../data/site.json';
const base = import.meta.env.BASE_URL === '/' ? '/' : import.meta.env.BASE_URL + '/';
---

<section class="section welcome" id="bienvenida">
  <div class="container welcome__inner">
    <!-- Text side -->
    <div class="welcome__text">
      <div class="welcome__tag reveal">
        <span class="section-label">Bienvenida oficial</span>
      </div>

      <h2 class="welcome__title reveal" style="animation-delay:0.1s">
        El reencuentro de la Primatología en el Perú
      </h2>

      <div class="welcome__body reveal" style="animation-delay:0.2s">
        <p>
          Bienvenidos al <strong>III Congreso Peruano de Primatología 2026</strong>. Tras años de espera, Lima se convierte en el punto de encuentro para compartir los avances e investigaciones que, desde cada rincón del país, protegen a nuestros primates neotropicales. 
        </p>
        <p>
          Bajo el lema <strong>'Todxs somos primatólogxs'</strong>, derribamos las barreras entre la comunidad científica, las comunidades rurales y la sociedad civil para crear un espacio único de intercambio, ciencia y acción.
        </p>
      </div>

      <div class="reveal" style="animation-delay:0.4s">
        <a href={`${base}inscripciones`} class="btn btn-primary">
          ¡Sé parte de la reactivación! →
        </a>
      </div>
    </div>

    <div class="welcome__visual reveal" aria-hidden="true">
      <div class="welcome__map-card card-glass">
        <h3 class="welcome__map-title">¿Qué encontrarás?</h3>
        <div class="welcome__map-items">
          <div class="welcome__map-item">
            <span class="welcome__map-flag">🏆</span>
            <span class="welcome__map-country">Conferencias Magistrales</span>
          </div>
          <div class="welcome__map-item">
            <span class="welcome__map-flag">🎤</span>
            <span class="welcome__map-country">Simposios y Ponencias</span>
          </div>
          <div class="welcome__map-item">
            <span class="welcome__map-flag">🛠️</span>
            <span class="welcome__map-country">Talleres</span>
          </div>
          <div class="welcome__map-item">
            <span class="welcome__map-flag">🤝</span>
            <span class="welcome__map-country">Espacios de colaboración</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .welcome {
    background: linear-gradient(180deg, var(--cream-warm) 0%, var(--cream) 100%);
    border-top: 1px solid rgba(82,183,136,0.1);
  }

  :global([data-theme="dark"]) .welcome {
    background: linear-gradient(180deg, #41240e 0%, #593414 100%);
  }

  .welcome__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
  }

  @media (min-width: 1024px) {
    .welcome__inner {
      grid-template-columns: 1.3fr 0.7fr;
      gap: 5rem;
    }
  }

  .welcome__text {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .welcome__title {
    font-family: var(--font-display);
    font-size: clamp(1.7rem, 3.5vw, 2.5rem);
    color: var(--forest-dark);
    line-height: 1.2;
  }
  :global([data-theme="dark"]) .welcome__title { color: var(--forest-canopy); }

  .welcome__body {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .welcome__body p {
    font-size: 0.97rem;
    color: var(--text-on-light);
    line-height: 1.8;
  }
  :global([data-theme="dark"]) .welcome__body p { color: rgba(240,237,232,0.85); }

  .welcome__stats {
    display: flex;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .welcome__stat {
    display: flex;
    flex-direction: column;
  }

  .welcome__stat-n {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 700;
    color: var(--forest-leaf);
    line-height: 1;
  }

  .welcome__stat-l {
    font-family: var(--font-ui);
    font-size: 0.72rem;
    color: var(--text-muted);
    font-weight: 500;
  }

  /* Visual card */
  .welcome__map-card {
    padding: 2rem;
  }

  .welcome__map-title {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--forest-leaf);
    margin-bottom: 1.5rem;
  }

  .welcome__map-items {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 1.75rem;
  }

  .welcome__map-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .welcome__map-flag { font-size: 1.75rem; }

  .welcome__map-country {
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--text-on-light);
  }
  :global([data-theme="dark"]) .welcome__map-country { color: var(--text-on-dark); }

  .welcome__map-info {
    font-size: 0.75rem;
    color: var(--text-muted);
  }

</style>
