---
import partners from '../../data/partners.json';
const base = import.meta.env.BASE_URL === '/' ? '/' : import.meta.env.BASE_URL + '/';
---

<section class="section partners" id="aliados">
  <div class="container">
    <div class="section-header reveal">
      <span class="section-label">Instituciones aliadas</span>
      <h2 class="section-title">Organizadores y Aliados</h2>
      <p class="section-subtitle">
        El congreso es posible gracias al apoyo de instituciones académicas, gubernamentales y de conservación comprometidas con la primatología latinoamericana.
      </p>
    </div>

    <div class="partners__grid reveal">
      {partners.map(partner => (
        <a
          href={partner.url.startsWith('/') ? `${base}${partner.url.substring(1)}` : partner.url}
          target={partner.url !== '#' ? '_blank' : undefined}
          rel="noopener noreferrer"
          class="partner-card"
          title={partner.name}
        >
          {partner.useLogo ? (
            <img src={`${base}${partner.logo}`} alt={`Logo ${partner.name}`} class="partner-card__logo" loading="lazy" />
          ) : (
            <div class="partner-card__acronym">{partner.acronym}</div>
          )}
          <div class="partner-card__name">{partner.name}</div>
        </a>
      ))}
    </div>

    <p class="partners__note reveal">
      ¿Tu institución quiere ser aliada del congreso?
      <a href={`${base}contacto`} class="partners__link">Contáctanos →</a>
    </p>
  </div>
</section>

<style>
  .partners {
    background: linear-gradient(180deg, var(--cream) 0%, var(--cream-warm) 100%);
  }

  :global([data-theme="dark"]) .partners {
    background: linear-gradient(180deg, #41240e 0%, #593414 100%);
  }

  .partners__grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1.25rem;
    margin-bottom: 3rem;
  }

  .partner-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    padding: 1.5rem 1rem;
    background: rgba(255,255,255,0.85);
    border-radius: var(--radius-md);
    border: 1px solid rgba(217,157,85,0.1);
    box-shadow: var(--shadow-sm);
    text-align: center;
    text-decoration: none;
    transition: all var(--transition-mid);
    min-height: 140px;
    width: 100%;
    max-width: calc(50% - 1rem);
  }

  @media (min-width: 640px) {
    .partner-card {
      max-width: calc(33.333% - 1rem);
    }
  }

  @media (min-width: 1024px) {
    .partner-card {
      max-width: calc(25% - 1rem);
    }
  }

  :global([data-theme="dark"]) .partner-card {
    background: rgba(26,58,46,0.5);
    border-color: rgba(217,157,85,0.15);
  }

  .partner-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
    border-color: rgba(217,157,85,0.3);
  }

  .partner-card__acronym {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--forest-mid);
    line-height: 1;
  }
  :global([data-theme="dark"]) .partner-card__acronym { color: var(--forest-canopy); }

  .partner-card__logo {
    max-width: 120px;
    max-height: 80px;
    object-fit: contain;
    margin-bottom: 0.4rem;
  }

  .partner-card__name {
    font-family: var(--font-ui);
    font-size: 0.65rem;
    color: var(--text-muted);
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .partners__note {
    text-align: center;
    font-size: 0.9rem;
    color: var(--text-muted);
  }

  .partners__link {
    color: var(--forest-leaf);
    font-weight: 600;
    margin-left: 0.25rem;
    transition: color var(--transition-fast);
  }
  .partners__link:hover { color: var(--forest-mid); }
</style>
