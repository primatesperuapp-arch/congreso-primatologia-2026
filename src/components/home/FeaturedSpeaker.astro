---
const base = import.meta.env.BASE_URL === '/' ? '/' : import.meta.env.BASE_URL + '/';

const featuredSpeakers = [
  {
    name: "Rosamira Guillén",
    subtitle: "Directora Ejecutiva de la Fundación Proyecto Tití",
    image: `${base}images/speakers/rosamira-guillen.jpg`,
    badge: "National Geographic Explorer",
    bio1: "Arquitecta y conservacionista colombiana, líder en la protección del <strong>Tití Cabeciblanco</strong>. Ganadora del Whitley Award y el National Geographic Buffett Award.",
    bio2: "En el III CPP 2026, Rosamira compartirá su experiencia liderando estrategias integrales que combinan ciencia, desarrollo comunitario y educación ambiental.",
    highlights: [
      { icon: "🌍", text: "Liderazgo Internacional" },
      { icon: "🐒", text: "Conservación de Especies" }
    ],
    color: "#8C374E"
  },
  {
    name: "Leandro Jerusalinsky",
    subtitle: "Coordinador del CPB - ICMBio/MMA",
    image: `${base}images/speakers/leandro-jerusalinsky.jpg`,
    initials: "LJ",
    badge: "IPS Special Presidential Award",
    bio1: "Coordinador del Centro Nacional de Investigación y Conservación de Primates y Xenartros (CPB) de Brasil y Vicepresidente del IUCN/SSC Primate Specialist Group.",
    bio2: "Experto en gestión de políticas públicas para la conservación de la biodiversidad, con más de 25 años dedicados al estudio de los primates neotropicales.",
    highlights: [
      { icon: "🇧🇷", text: "Gestión Pública" },
      { icon: "🛡️", text: "Políticas de Conservación" }
    ],
    color: "#c9a84c"
  },
  {
    name: "Citlalli Morelos Juárez",
    subtitle: "Directora de la Reserva Tesoro Escondido",
    image: `${base}images/speakers/citlalli-morelos.jpg`,
    initials: "CM",
    badge: "WINGS WorldQuest Fellow",
    bio1: "Impulsora de programas de parabiólogas y protección del mono araña de cabeza marrón en el Chocó ecuatoriano. PhD por la Universidad de Sussex.",
    bio2: "Galardonada como Fellow del WINGS WorldQuest Women of Discovery Award y nominada oficial para el prestigioso Indianapolis Prize.",
    highlights: [
      { icon: "🤝", text: "Empoderamiento Local" },
      { icon: "🎓", text: "Investigación PhD" }
    ],
    color: "#2d6a4f"
  }
];
---

<section class="section spotlight" id="featured-slider">
  <div class="spotlight__slider">
    <div class="spotlight__track" id="slider-track">
      {featuredSpeakers.map((speaker, index) => (
        <div class={`spotlight__slide ${index === 0 ? 'active' : ''}`} data-index={index}>
          <div class="container spotlight__inner">
            <div class="spotlight__visual">
              <div class="spotlight__image-wrapper" style={`--accent: ${speaker.color}`}>
                {speaker.image ? (
                  <img 
                    src={speaker.image} 
                    alt={`${speaker.name} - Ponente Magistral`} 
                    class="spotlight__img"
                  />
                ) : (
                  <div class="spotlight__placeholder" style={`background: linear-gradient(135deg, ${speaker.color}, ${speaker.color}cc);`}>
                    {speaker.initials}
                  </div>
                )}
                <div class="spotlight__badge">
                  <span class="badge badge-accent">{speaker.badge}</span>
                </div>
              </div>
            </div>

            <div class="spotlight__content">
              <div class="spotlight__header">
                <span class="section-label">Ponente Magistral Confirmado/a</span>
                <h2 class="spotlight__title">{speaker.name}</h2>
                <p class="spotlight__subtitle">{speaker.subtitle}</p>
              </div>

              <div class="spotlight__body">
                <p set:html={speaker.bio1}></p>
                <p>{speaker.bio2}</p>
              </div>

              <div class="spotlight__footer">
                <div class="spotlight__highlights">
                  {speaker.highlights.map(h => (
                    <div class="spotlight__highlight">
                      <span class="highlight-icon">{h.icon}</span>
                      <span class="highlight-text">{h.text}</span>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Navigation -->
    <div class="spotlight__controls container">
      <button class="spotlight__nav-btn prev" id="prev-btn" aria-label="Anterior ponente">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M15 18l-6-6 6-6"/></svg>
      </button>
      
      <div class="spotlight__dots" id="slider-dots">
        {featuredSpeakers.map((_, i) => (
          <button class={`spotlight__dot ${i === 0 ? 'active' : ''}`} data-index={i} aria-label={`Ir a ponente ${i + 1}`}></button>
        ))}
      </div>

      <button class="spotlight__nav-btn next" id="next-btn" aria-label="Siguiente ponente">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 18l6-6-6-6"/></svg>
      </button>
    </div>
  </div>
</section>

<script>
  function initSlider() {
    const slider = document.getElementById('featured-slider');
    if (!slider || slider.dataset.initialized) return;
    slider.dataset.initialized = "true";

    const track = document.getElementById('slider-track');
    const slides = document.querySelectorAll('.spotlight__slide');
    const dots = document.querySelectorAll('.spotlight__dot');
    const prevBtn = document.getElementById('prev-btn');
    const nextBtn = document.getElementById('next-btn');
    
    if (!track || slides.length === 0) return;

    let currentIndex = 0;
    let intervalId;

    function updateSlider(index) {
      slides.forEach(s => s.classList.remove('active'));
      dots.forEach(d => d.classList.remove('active'));
      
      currentIndex = (index + slides.length) % slides.length;
      
      slides[currentIndex].classList.add('active');
      dots[currentIndex].classList.add('active');
      
      // Reiniciar el auto-play al interactuar
      startInterval();
    }

    function startInterval() {
      if (intervalId) clearInterval(intervalId);
      intervalId = setInterval(() => {
        updateSlider(currentIndex + 1);
      }, 8000);
    }

    prevBtn?.addEventListener('click', () => updateSlider(currentIndex - 1));
    nextBtn?.addEventListener('click', () => updateSlider(currentIndex + 1));
    
    dots.forEach((dot, i) => {
      dot.addEventListener('click', () => updateSlider(i));
    });

    startInterval();
  }

  // Ejecutar en carga y tras navegación de Astro
  initSlider();
  document.addEventListener('astro:page-load', initSlider);
</script>

<style>
  .spotlight {
    background: linear-gradient(135deg, var(--forest-darkest) 0%, #4a2b11 100%);
    color: white;
    padding: 6rem 0;
    overflow: hidden;
    position: relative;
  }

  .spotlight__slider {
    position: relative;
    width: 100%;
  }

  .spotlight__track {
    position: relative;
    min-height: 650px;
    display: grid;
    grid-template-columns: 1fr;
    align-items: center;
  }

  @media (min-width: 1024px) {
    .spotlight__track { min-height: 550px; }
  }

  .spotlight__slide {
    grid-area: 1 / 1 / 2 / 2;
    opacity: 0;
    visibility: hidden;
    transform: translateX(30px) scale(0.98);
    transition: all 0.85s cubic-bezier(0.23, 1, 0.32, 1);
    pointer-events: none;
  }

  .spotlight__slide.active {
    opacity: 1;
    visibility: visible;
    transform: translateX(0) scale(1);
    pointer-events: auto;
  }

  .spotlight__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3.5rem;
    align-items: center;
  }

  @media (min-width: 1024px) {
    .spotlight__inner {
      grid-template-columns: 0.9fr 1.1fr;
      gap: 5rem;
    }
  }

  /* ── Visual ──────────────────────────────────────── */
  .spotlight__visual {
    position: relative;
    display: flex;
    justify-content: center;
  }

  .spotlight__image-wrapper {
    position: relative;
    width: 100%;
    max-width: 450px;
    aspect-ratio: 4/3;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: 0 20px 50px rgba(0,0,0,0.5);
    border: 1px solid rgba(217,157,85,0.2);
    background: rgba(255,255,255,0.03);
  }

  .spotlight__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform var(--transition-slow);
  }

  .spotlight__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: 5rem;
    font-weight: 700;
    color: rgba(255,255,255,0.9);
  }

  .spotlight__badge {
    position: absolute;
    bottom: 1.5rem;
    left: 1.5rem;
    z-index: 2;
  }

  .badge-accent {
    background: #FFCC00;
    color: #000;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.5rem 1rem;
    font-size: 0.75rem;
    border-radius: 4px;
    box-shadow: 0 4px 15px rgba(0,0,0,0.3);
  }

  /* ── Content ─────────────────────────────────────── */
  .spotlight__content {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    min-height: 380px; /* Ensure consistent text area height */
    justify-content: center;
  }

  .spotlight__title {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 4.5vw, 3.2rem);
    color: var(--gold-light);
    margin: 0.5rem 0;
    line-height: 1.1;
  }

  .spotlight__subtitle {
    font-family: var(--font-ui);
    font-size: 1.15rem;
    color: rgba(255,255,255,0.7);
    font-weight: 600;
  }

  .spotlight__body {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .spotlight__body p {
    font-size: 1.1rem;
    line-height: 1.8;
    color: rgba(255,255,255,0.85);
  }

  :global(.spotlight__body strong) {
    color: var(--gold-light);
    font-weight: 700;
  }

  /* ── Footer ──────────────────────────────────────── */
  .spotlight__highlights {
    display: flex;
    gap: 1.5rem;
    margin-top: 1rem;
    flex-wrap: wrap;
  }

  .spotlight__highlight {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    background: rgba(255,255,255,0.06);
    padding: 0.75rem 1.25rem;
    border-radius: 100px;
    border: 1px solid rgba(217,157,85,0.15);
  }

  .highlight-icon { font-size: 1.25rem; }
  
  .highlight-text {
    font-family: var(--font-ui);
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    color: var(--cream);
  }

  /* ── Controls ────────────────────────────────────── */
  .spotlight__controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 2rem;
    margin-top: 3rem;
  }

  @media (min-width: 1024px) {
    .spotlight__controls {
      justify-content: flex-start;
      padding-left: calc(0.9fr + 5rem); /* Align with content */
      margin-top: 2rem;
    }
  }

  .spotlight__nav-btn {
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.2);
    color: white;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .spotlight__nav-btn:hover {
    background: var(--gold-light);
    color: var(--forest-darkest);
    border-color: var(--gold-light);
    transform: scale(1.1);
  }

  .spotlight__dots {
    display: flex;
    gap: 0.75rem;
  }

  .spotlight__dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: rgba(255,255,255,0.3);
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
    padding: 0;
  }

  .spotlight__dot.active {
    background: var(--gold-light);
    transform: scale(1.3);
    box-shadow: 0 0 10px var(--gold-light);
  }
</style>
