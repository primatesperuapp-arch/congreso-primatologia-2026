---
import objectives from '../../data/objectives.json';

const colorMap: Record<string, string> = {
  green:  'var(--forest-leaf)',
  forest: 'var(--forest-mid)',
  earth:  'var(--earth-warm)',
  gold:   'var(--gold)',
};
---

<section class="section objectives" id="objetivos">
  <div class="pattern-hojas" style="position:absolute;inset:0;pointer-events:none;z-index:0;"></div>
  <div class="container" style="position:relative;z-index:1;">
    <div class="section-header reveal">
      <span class="section-label">¿Por qué este congreso?</span>
      <h2 class="section-title">Objetivos del Congreso</h2>
      <p class="section-subtitle">
        Un espacio para construir conocimiento colectivo, fortalecer redes y transformar la conservación de primates en el Perú y Latinoamérica.
      </p>
    </div>

    <div class="objectives__grid">
      {objectives.map((obj, i) => (
        <article
          class={`objective-card reveal reveal-delay-${(i % 4) + 1}`}
          style={`--accent: ${colorMap[obj.color] || colorMap.green};`}
        >
          <div class="objective-card__icon" aria-hidden="true">{obj.icon}</div>
          <div class="objective-card__accent"></div>
          <h3 class="objective-card__title">{obj.title}</h3>
          <p class="objective-card__desc">{obj.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .objectives {
    position: relative;
    background: var(--cream-warm);
  }

  :global([data-theme="dark"]) .objectives {
    background: linear-gradient(180deg, #0d2318 0%, #0a1f14 100%);
  }

  .objectives__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  @media (min-width: 640px) {
    .objectives__grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 1024px) {
    .objectives__grid { grid-template-columns: repeat(3, 1fr); }
  }

  .objective-card {
    position: relative;
    padding: 2rem 1.75rem;
    background: rgba(255,255,255,0.85);
    border-radius: var(--radius-lg);
    border: 1px solid rgba(82,183,136,0.12);
    box-shadow: var(--shadow-sm);
    transition: transform var(--transition-mid), box-shadow var(--transition-mid);
    overflow: hidden;
  }

  :global([data-theme="dark"]) .objective-card {
    background: rgba(26, 58, 46, 0.55);
    border-color: rgba(82,183,136,0.18);
  }

  .objective-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-md), 0 0 25px rgba(82,183,136,0.12);
  }

  .objective-card__accent {
    position: absolute;
    top: 0; left: 0;
    width: 4px;
    height: 100%;
    background: var(--accent);
    border-radius: 4px 0 0 4px;
  }

  .objective-card__icon {
    font-size: 2.2rem;
    margin-bottom: 1rem;
    display: block;
  }

  .objective-card__title {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-on-light);
    margin-bottom: 0.6rem;
    line-height: 1.3;
  }

  :global([data-theme="dark"]) .objective-card__title {
    color: var(--text-on-dark);
  }

  .objective-card__desc {
    font-size: 0.875rem;
    color: var(--text-muted);
    line-height: 1.65;
  }
</style>
