---
import site from '../../data/site.json';
const base = import.meta.env.BASE_URL === '/' ? '/' : import.meta.env.BASE_URL + '/';
---

<section class="hero" aria-label="Presentación del congreso">
  <!-- Background layers -->
  <div class="hero__bg">
    <div class="hero__bg-gradient"></div>
    <div class="hero__bg-pattern"></div>
    <div class="hero__particles" aria-hidden="true">
      {Array.from({length: 12}).map((_, i) => (
        <div class="hero__particle" style={`--delay: ${i * 0.4}s; --x: ${10 + i * 7}%; --size: ${4 + (i % 4) * 3}px;`}></div>
      ))}
    </div>
  </div>

  <div class="container hero__content">
    <!-- Left Column -->
    <div class="hero__text">
      <!-- Label -->
      <div class="hero__label animate-fade-up" style="animation-delay: 0.1s">
        <span class="badge badge-leaf">🇵🇪 Lima, Perú</span>
        <span class="badge badge-gold">30 de julio al 02 de agosto, 2026</span>
      </div>

      <!-- Main Logo Banner -->
      <div class="hero__logo-container animate-fade-up" style="animation-delay: 0.2s">
        <img 
          src={`${base}images/logos/logo-principal.png`} 
          alt="III Congreso Peruano de Primatología - Lima 2026" 
          class="hero__logo-img"
        />
        <h1 class="sr-only">III Congreso Peruano de Primatología 2026</h1>
      </div>

      <!-- Slogan -->
      <p class="hero__slogan animate-fade-up" style="animation-delay: 0.35s">
        {site.slogan}
      </p>

      <!-- CTA Buttons -->
      <div class="hero__ctas animate-fade-up" style="animation-delay: 0.5s">
        <a href={`${base}llamado-de-resumenes`} class="btn btn-primary btn-lg">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14,2 14,8 20,8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
          Enviar Resumen
        </a>
        <a href={`${base}inscripciones`} class="btn btn-gold btn-lg">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          Inscribirse
        </a>
      </div>

      <!-- Countdown -->
      <div class="hero__countdown animate-fade-up" style="animation-delay: 0.6s">
        <span class="countdown-label">Faltan:</span>
        <div class="countdown-grid" id="countdown">
          <div class="countdown-item">
            <span class="countdown-number" id="days">00</span>
            <span class="countdown-text">Días</span>
          </div>
          <div class="countdown-item">
            <span class="countdown-number" id="hours">00</span>
            <span class="countdown-text">Horas</span>
          </div>
          <div class="countdown-item">
            <span class="countdown-number" id="minutes">00</span>
            <span class="countdown-text">Min</span>
          </div>
          <div class="countdown-item">
            <span class="countdown-number" id="seconds">00</span>
            <span class="countdown-text">Seg</span>
          </div>
        </div>
      </div>

      <!-- Stats -->
      <div class="hero__stats animate-fade-up" style="animation-delay: 0.65s">
        <div class="hero__stat">
          <span class="hero__stat-number">4</span>
          <span class="hero__stat-label">Días</span>
        </div>
        <div class="hero__stat-divider" aria-hidden="true"></div>
        <div class="hero__stat">
          <span class="hero__stat-number">5</span>
          <span class="hero__stat-label">Ejes Temáticos</span>
        </div>
        <div class="hero__stat-divider" aria-hidden="true"></div>
        <div class="hero__stat">
          <span class="hero__stat-number">+20</span>
          <span class="hero__stat-label">Países</span>
        </div>
        <div class="hero__stat-divider" aria-hidden="true"></div>
        <div class="hero__stat">
          <span class="hero__stat-number">+200</span>
          <span class="hero__stat-label">Participantes</span>
        </div>
      </div>
    </div>

    <!-- Right Column — Visual -->
    <div class="hero__visual animate-fade-up" style="animation-delay: 0.3s">
      <div class="hero__banner-wrapper">
        <img src={`${base}images/banners/hero-banner.png`} alt="Afiche Oficial del III Congreso Peruano de Primatología" class="hero__banner-img" />
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="hero__scroll-hint" aria-label="Desplázate hacia abajo">
    <div class="hero__scroll-line"></div>
    <span>Explorar</span>
  </div>
</section>

<style>
  /* ── Hero Base ───────────────────────────────────── */
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    overflow: hidden;
  }

  /* ── Backgrounds ─────────────────────────────────── */
  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero__bg-gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      135deg,
      #593414 0%,
      #8c6239 50%,
      #593414 100%
    );
  }

  .hero__bg-pattern {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(circle at 20% 50%, rgba(217,157,85,0.15) 0%, transparent 50%),
      radial-gradient(circle at 80% 20%, rgba(242,235,223,0.1) 0%, transparent 40%);
  }

  /* Floating particles */
  .hero__particles {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  .hero__particle {
    position: absolute;
    bottom: -10px;
    left: var(--x);
    width: var(--size);
    height: var(--size);
    border-radius: 50%;
    background: rgba(217, 157, 85, 0.4);
    animation: rise 8s ease-in infinite;
    animation-delay: var(--delay);
  }

  @keyframes rise {
    0%   { transform: translateY(0) scale(1); opacity: 0.6; }
    100% { transform: translateY(-100vh) scale(0.3); opacity: 0; }
  }

  /* ── Layout ──────────────────────────────────────── */
  .hero__content {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
    padding-top: 5rem;
    padding-bottom: 4rem;
  }

  @media (min-width: 1024px) {
    .hero__content {
      grid-template-columns: 1.1fr 0.9fr;
      gap: 4rem;
      padding-top: 6rem;
    }
  }

  /* ── Text Column ─────────────────────────────────── */
  .hero__text {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .hero__label {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .badge-leaf {
    background: rgba(242, 235, 223, 0.1);
    color: #f2ebdf;
    border: 1px solid rgba(242, 235, 223, 0.3);
    padding: 0.35rem 0.9rem;
    border-radius: 100px;
    font-family: var(--font-ui);
    font-size: 0.8rem;
    font-weight: 600;
  }

  .badge-gold {
    background: rgba(201, 168, 76, 0.2);
    color: var(--gold-light);
    border: 1px solid rgba(201, 168, 76, 0.35);
    padding: 0.35rem 0.9rem;
    border-radius: 100px;
    font-family: var(--font-ui);
    font-size: 0.8rem;
    font-weight: 600;
  }

  .hero__logo-container {
    max-width: 550px;
    margin-bottom: 1rem;
  }

  .hero__logo-img {
    width: 100%;
    height: auto;
    display: block;
    filter: drop-shadow(0 8px 30px rgba(0,0,0,0.4));
  }

  @media (max-width: 768px) {
    .hero__logo-container {
      max-width: 320px;
      margin: 0 auto;
    }
  }

  .hero__slogan {
    font-family: var(--font-body);
    font-size: clamp(0.95rem, 2vw, 1.1rem);
    color: rgba(255,255,255,0.72);
    line-height: 1.75;
    max-width: 500px;
    border-left: 3px solid var(--forest-leaf);
    padding-left: 1rem;
  }

  .hero__ctas {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    align-items: center;
  }

  /* ── Stats ───────────────────────────────────────── */
  .hero__stats {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 1.25rem 1.5rem;
    background: rgba(255,255,255,0.06);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(217,157,85,0.2);
    border-radius: var(--radius-lg);
    width: fit-content;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .hero__stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
  }

  .hero__stat-number {
    font-family: var(--font-display);
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--forest-canopy);
    line-height: 1;
  }

  .hero__stat-label {
    font-family: var(--font-ui);
    font-size: 0.7rem;
    color: rgba(255,255,255,0.55);
    font-weight: 500;
    text-align: center;
  }

  .hero__stat-divider {
    width: 1px;
    height: 36px;
    background: rgba(217,157,85,0.25);
  }

  /* ── Visual Column ───────────────────────────────── */
  .hero__visual {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .hero__banner-wrapper {
    position: relative;
    width: 100%;
    max-width: 550px;
    display: flex;
    align-items: center;
    justify-content: center;
    filter: drop-shadow(0 20px 40px rgba(0,0,0,0.6));
    transition: transform var(--transition-slow);
  }

  .hero__banner-wrapper:hover {
    transform: translateY(-8px);
  }

  .hero__banner-img {
    width: 100%;
    height: auto;
    object-fit: contain;
    /* Efecto sutil para integrarlo mejor con el fondo oscuro */
    filter: brightness(1.05) contrast(1.02);
  }

  @media (max-width: 1023px) {
    .hero__banner-wrapper { max-width: 380px; }
  }

  /* ── Scroll hint ─────────────────────────────────── */
  .hero__scroll-hint {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    z-index: 1;
  }

  .hero__scroll-line {
    width: 1px;
    height: 50px;
    background: linear-gradient(to bottom, rgba(217,157,85,0.8), transparent);
    animation: scroll-line 1.5s ease-in-out infinite;
  }

  @keyframes scroll-line {
    0%, 100% { transform: scaleY(1); opacity: 1; }
    50%       { transform: scaleY(0.5); opacity: 0.4; }
  }

  .hero__scroll-hint span {
    font-family: var(--font-ui);
    font-size: 0.7rem;
    color: rgba(255,255,255,0.4);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  /* ── Countdown ───────────────────────────────────── */
  .hero__countdown {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-top: 0.5rem;
  }

  .countdown-label {
    font-family: var(--font-ui);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--forest-canopy);
    font-weight: 700;
  }

  .countdown-grid {
    display: flex;
    gap: 0.75rem;
  }

  .countdown-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    background: rgba(0, 0, 0, 0.2);
    border: 1px solid rgba(217, 157, 85, 0.2);
    padding: 0.4rem 0.6rem;
    border-radius: var(--radius-md);
    min-width: 55px;
  }

  .countdown-number {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--gold-light);
    line-height: 1.1;
  }

  .countdown-text {
    font-family: var(--font-ui);
    font-size: 0.6rem;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.5);
    letter-spacing: 0.05em;
    font-weight: 500;
  }

  @media (max-width: 640px) {
    .hero__countdown {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.75rem;
    }
  }

  /* Ensure animations only play once on load */
  .animate-fade-up {
    opacity: 0;
    animation: fadeInUp 0.7s ease forwards;
  }
</style>

<script>
  function initCountdown() {
    // Target: July 30, 2026, 9:00 AM
    const targetDate = new Date('2026-07-30T09:00:00').getTime();
    
    const daysEl = document.getElementById('days');
    const hoursEl = document.getElementById('hours');
    const minutesEl = document.getElementById('minutes');
    const secondsEl = document.getElementById('seconds');
    const containerEl = document.getElementById('countdown');

    if (!daysEl || !hoursEl || !minutesEl || !secondsEl) return;

    function update() {
      const now = new Date().getTime();
      const diff = targetDate - now;

      if (diff <= 0) {
        if (containerEl) containerEl.innerHTML = '<span style="color:var(--forest-canopy); font-weight:700;">¡EL CONGRESO HA COMENZADO!</span>';
        return;
      }

      const d = Math.floor(diff / (1000 * 60 * 60 * 24));
      const h = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
      const m = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
      const s = Math.floor((diff % (1000 * 60)) / 1000);

      daysEl.innerText = d.toString().padStart(2, '0');
      hoursEl.innerText = h.toString().padStart(2, '0');
      minutesEl.innerText = m.toString().padStart(2, '0');
      secondsEl.innerText = s.toString().padStart(2, '0');
    }

    setInterval(update, 1000);
    update();
  }

  // Initialize on load and on view change (Astro transitions if enabled)
  initCountdown();
  document.addEventListener('astro:page-load', initCountdown);
</script>
