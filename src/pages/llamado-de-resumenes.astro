---
import PageLayout from '../layouts/PageLayout.astro';
import axes from '../data/thematic-axes.json';
const base = import.meta.env.BASE_URL === '/' ? '/' : import.meta.env.BASE_URL + '/';

const faqs = [
  {
    q: "¿Cuántas palabras puede tener el resumen?",
    a: "Los resúmenes para ponencias orales y pósters deben tener entre 250 y 350 palabras, sin incluir el título ni los autores. Los simposios pueden enviar hasta 400 palabras de descripción general."
  },
  {
    q: "¿Puedo enviar más de un resumen?",
    a: "Sí, cada autor puede ser primer autor de un máximo de 2 resúmenes, y coautor sin límite de número."
  },
  {
    q: "¿En qué idioma debo enviar el resumen?",
    a: "Se aceptan resúmenes en español e inglés. Para esta edición, el español es el idioma principal del congreso."
  },
  {
    q: "¿Cómo serán evaluados los resúmenes?",
    a: "Cada resumen será revisado por al menos dos miembros del comité científico en proceso de doble ciego. Se evaluará: relevancia temática, claridad, originalidad, metodología y aporte a la conservación."
  },
  {
    q: "¿Los autores aceptados deben inscribirse al congreso?",
    a: "Sí. La aceptación del resumen no incluye la inscripción. Todos los autores que presenten deben estar inscritos antes de la fecha límite indicada."
  },
  {
    q: "¿Se publicarán los resúmenes aceptados?",
    a: "Los resúmenes aceptados serán publicados en el libro de resúmenes del congreso con ISBN. Estamos explorando opciones de publicación de artículos completos en revistas afiliadas."
  },
];

const guidelines = [
  { icon: "📏", title: "Extensión", desc: "El resumen descriptivo o analítico debe contener un máximo de 300 palabras." },
  { icon: "📊", title: "Formato empírico", desc: "Incluir claramente Contexto/Justificación, Metodología/Diseño, Resultados Clave e Implicaciones para la conservación." },
  { icon: "📖", title: "Formato de relatos", desc: "Incluir Situación abordada, Acciones implementadas, Desafíos superados e Impacto en la comunidad/biodiversidad." },
  { icon: "🤝", title: "Lenguaje y Ética", desc: "Fomentamos el uso de lenguaje inclusivo y ética taxonómica. Proyectos con pueblos indígenas deben certificar consentimiento informado." },
];
---

<PageLayout
  title="Llamado de Resúmenes"
  description="Llamado a la Presentación de Resúmenes: III Congreso Peruano de Primatología. Integrando Ciencias, Saberes y Sociedad para la Conservación en el Perú."
  heroTitle="Llamado de Resúmenes"
  heroSubtitle="III Congreso Peruano de Primatología: Integrando Ciencias, Saberes y Sociedad para la Conservación en el Perú"
  heroColor="var(--forest-mid)"
>

  <!-- Intro + Deadline Alert -->
  <section class="section">
    <div class="container">
      <div class="call-intro">
        <div class="deadline-alert reveal">
          <div class="deadline-alert__icon">📅</div>
          <div class="deadline-alert__text">
            <strong>Apertura:</strong> 8 de mayo 2026 &nbsp;|&nbsp; <strong>Cierre:</strong> 15 de junio 2026
          </div>
          <div class="deadline-alert__actions" style="display: flex; gap: 0.75rem; flex-wrap: wrap;">
            <a href="/documentos/Modelo_resumen_CPP2026.docx" download class="btn btn-secondary">
              📥 Plantilla Word
            </a>
            <a href="https://forms.gle/Gzcr2ktTmrEnGTTh9" target="_blank" rel="noopener" class="btn btn-primary">
              Enviar Resumen →
            </a>
          </div>
        </div>

        <p class="call-desc reveal">
          <strong>Lugar:</strong> Facultad de Medicina Veterinaria UNMSM (Av. Circunvalación 28, San Borja, Lima).<br /><br />
          El Comité Organizador del III Congreso Peruano de Primatología se complace en invitar a investigadores, estudiantes, gestores de áreas protegidas, organizaciones indígenas, comunidades locales, centros de rescate y fotógrafos de conservación a presentar sus propuestas. 
          Alineados con el Plan Nacional de Conservación de Primates Amenazados del Perú (2019-2029) impulsado por el SERFOR, este congreso es una plataforma para articular esfuerzos interdisciplinarios y construir soluciones de manejo colaborativo.
          Hacemos un llamado a investigaciones rigurosas y experiencias de base que exploren la biología evolutiva, el bienestar animal y el rol humano en la persistencia de las especies.
        </p>
      </div>
    </div>
  </section>

  <!-- Categorías -->
  <section class="section" style="background: var(--cream-warm);">
    <div class="container">
      <div class="section-header reveal">
        <span class="section-label">Áreas temáticas</span>
        <h2 class="section-title">Categorías Temáticas</h2>
      </div>

      <div class="axes-list reveal">
        {axes.map(axis => (
          <div class="axis-row" style={`--c: ${axis.color};`}>
            <div class="axis-row__emoji">{axis.emoji}</div>
            <div class="axis-row__info">
              <span class="axis-row__code" style={`color: ${axis.color};`}>[{axis.code}]</span>
              <strong class="axis-row__name">{axis.title}</strong>
              <span class="axis-row__desc">{axis.description}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Formatos -->
  <section class="section">
    <div class="container">
      <div class="section-header reveal">
        <span class="section-label">¿Cómo participar?</span>
        <h2 class="section-title">Formatos de Presentación</h2>
      </div>

      <div class="formats-grid">
        {[
          { icon: "🎤", name: "Ponencias Orales", time: "15 min", desc: "Presentación de datos empíricos, resultados de investigaciones biológicas o análisis sociales cuantitativos/cualitativos.", badge: "" },
          { icon: "📖", name: "Relatos de Experiencia", time: "15 min", desc: "Modalidad para gestores y comunidades; se centra en la narrativa práctica de la conservación y lecciones operativas.", badge: "Práctico" },
          { icon: "⚡", name: "Charlas Relámpago", time: "5 min", desc: "Formato visual ágil para investigaciones en curso, innovaciones tecnológicas o denuncias de conservación.", badge: "Lightning" },
          { icon: "📌", name: "Pósteres y Exposiciones", time: "Digital / Físico", desc: "Infografías científicas, mapas participativos o colecciones de fotografía/arte orientadas a la divulgación.", badge: "" },
          { icon: "🗣️", name: "Simposios / Mesas Redondas", time: "90 min", desc: "Panel multidisciplinario para discutir temas críticos, garantizando la integración de diversas voces.", badge: "90 min" },
          { icon: "🛠️", name: "Talleres Colaborativos", time: "Sesiones", desc: "Sesiones de transferencia de habilidades prácticas, técnicas, analíticas o de políticas.", badge: "" }
        ].map((f, i) => (
          <div class={`format-card reveal reveal-delay-${i+1}`}>
            <div class="format-card__icon">{f.icon}</div>
            {f.badge && <span class="format-card__badge">{f.badge}</span>}
            <h3 class="format-card__name">{f.name}</h3>
            <div class="format-card__time">⏱ {f.time}</div>
            <p class="format-card__desc">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Lineamientos -->
  <section class="section" style="background: var(--cream-warm);">
    <div class="container">
      <div class="section-header reveal">
        <span class="section-label">Instrucciones</span>
        <h2 class="section-title">Lineamientos de Envío</h2>
        <p class="section-subtitle">Asegúrate de que tu propuesta cumpla con los estándares del congreso para facilitar su evaluación.</p>
      </div>

      <div class="requirements-grid reveal">
        <div class="requirement-box">
          <div style="display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 1.5rem;">
            <div>
              <h3>📋 Requisitos Generales</h3>
              <ul>
                <li>Envío exclusivo a través del <strong>formulario oficial</strong> en línea.</li>
                <li>Extensión máxima de <strong>300 palabras</strong> para el resumen descriptivo.</li>
                <li>El título debe reflejar claramente el <strong>objetivo y la idea principal</strong> del trabajo.</li>
                <li><strong>Inclusión Lingüística:</strong> Opción de adjuntar síntesis en lengua originaria (Quechua, Awajún, etc.).</li>
              </ul>
            </div>
            <a href="/documentos/Modelo_resumen_CPP2026.docx" download class="btn btn-secondary" style="flex-shrink: 0; display: inline-flex; align-items: center; gap: 0.5rem;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
              Descargar Plantilla (.docx)
            </a>
          </div>
        </div>
      </div>

      <div class="structure-section reveal">
        <h3>📐 Estructura del Resumen</h3>
        <p>El contenido debe organizarse según la categoría de tu participación:</p>
        
        <div class="structure-grid">
          <div class="structure-card">
            <h4>Científicas (Empíricas)</h4>
            <p>Incluir: Contexto/objetivo, métodos (diseño, muestra), resultados (datos concretos) y conclusiones.</p>
          </div>
          <div class="structure-card">
            <h4>Relatos Comunitarios / Descriptivos</h4>
            <p>Incluir: Situación/problemática, acciones implementadas, desafíos superados e impacto real.</p>
          </div>
        </div>
      </div>
    </div>
  <!-- Criterios de Evaluación -->
  <section class="section">
    <div class="container">
      <div class="section-header reveal">
        <span class="section-label">Proceso de Evaluación</span>
        <h2 class="section-title">Evaluación por Pares</h2>
        <p class="section-subtitle">
          Un Comité Científico Transdisciplinario revisará los resúmenes mediante un proceso ciego, empleando rúbricas que valoran la solidez técnica y la aplicabilidad práctica según el Plan Nacional del SERFOR (hábitats, caza y gobernanza).
        </p>
      </div>

      <div class="policy-table reveal">
        <table>
          <thead>
            <tr>
              <th>Dimensión</th>
              <th>Enfoque Académico / Tecnológico</th>
              <th>Enfoque de Relatos / Divulgación</th>
              <th>Peso</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td><strong>Relevancia Estratégica</strong></td>
              <td>Aborda vacíos y se vincula al Plan Nacional SERFOR.</td>
              <td>Responde a amenazas locales o carencias educativas.</td>
              <td class="policy-green">20%</td>
            </tr>
            <tr>
              <td><strong>Rigor Metodológico</strong></td>
              <td>Diseño robusto, replicable y ético.</td>
              <td>Planificación estructurada y conocimiento del contexto.</td>
              <td class="policy-green">25%</td>
            </tr>
            <tr>
              <td><strong>Impacto y Efectividad</strong></td>
              <td>Provee modelos predictivos, teóricos o de manejo.</td>
              <td>Impactos tangibles (reducción de caza, empoderamiento).</td>
              <td class="policy-green">25%</td>
            </tr>
            <tr>
              <td><strong>Equidad y Ética</strong></td>
              <td>Evita "ciencia paracaidista", colabora con pares locales.</td>
              <td>Respeta saberes originarios y asegura representatividad.</td>
              <td class="policy-green">15%</td>
            </tr>
            <tr>
              <td><strong>Claridad Expositiva</strong></td>
              <td>Excepcionalmente claro, sin jerga inaccesible.</td>
              <td>Narrativa coherente, ilustra lecciones aprendidas.</td>
              <td class="policy-green">15%</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Lenguaje Inclusivo -->
  <section class="section" style="background: var(--cream-warm);">
    <div class="container">
      <div class="section-header reveal">
        <span class="section-label">Lineamientos Éticos</span>
        <h2 class="section-title">Lenguaje y Terminología Descolonizada</h2>
      </div>

      <div class="guidelines-grid">
        <div class="guideline-card reveal">
          <span class="guideline-card__icon">🐒</span>
          <h3 class="guideline-card__title">Terminología de Especies</h3>
          <p class="guideline-card__desc">Se desaconseja el término "Monos del Nuevo Mundo". Instamos a usar designaciones taxonómicas (Platirrinos) o nombres vernáculos originarios (ej. sugkamat, musmuqui, maquisapa).</p>
        </div>
        <div class="guideline-card reveal reveal-delay-2">
          <span class="guideline-card__icon">🧑🏽‍🌾</span>
          <h3 class="guideline-card__title">Denominación de Comunidades</h3>
          <p class="guideline-card__desc">Evitar lenguaje genérico o paternalista como "los pobladores" o "tribus". Identificar específicamente a la Nación o Pueblo con el que se colabora (ej. Nación Awajún, Pueblo Kichwa).</p>
        </div>
        <div class="guideline-card reveal reveal-delay-3">
          <span class="guideline-card__icon">🗣️</span>
          <h3 class="guideline-card__title">Inclusión Lingüística</h3>
          <p class="guideline-card__desc">Se permite y fomenta enviar una versión complementaria del resumen o video corto en lenguas originarias relevantes para la zona de estudio (Quechua, Aymara, Shipibo-Konibo, etc.).</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Becas de Accesibilidad -->
  <section class="section">
    <div class="container">
      <div class="scholarship-box reveal">
        <div class="scholarship-box__content">
          <span class="section-label">Equidad y Compromiso</span>
          <h2 class="section-title">Becas de Accesibilidad</h2>
          <p>
            Reafirmando nuestro compromiso con la equidad, el congreso dispondrá de un número limitado de <strong>Becas de Apoyo de Viaje y Conectividad</strong> destinadas prioritariamente a miembros de organizaciones locales de la Amazonía/Andes, estudiantes peruanos e investigadores en etapas tempranas de su carrera.
          </p>
          <p style="margin-top: 1rem; font-size: 0.9rem; opacity: 0.8;">
            * Las bases de postulación se encuentran disponibles en nuestro portal de inscripciones.
          </p>
        </div>
        <div class="scholarship-box__icon">🎓</div>
      </div>
    </div>
  </section>

  <!-- FAQ Acordeón -->
  <section class="section">
    <div class="container">
      <div class="section-header reveal">
        <span class="section-label">Preguntas frecuentes</span>
        <h2 class="section-title">FAQ — Resúmenes</h2>
      </div>

      <div class="faq-list reveal" id="faq-container">
        {faqs.map((faq, i) => (
          <details class="faq-item" id={`faq-${i}`}>
            <summary class="faq-item__question">
              <span>{faq.q}</span>
              <svg class="faq-item__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                <polyline points="6 9 12 15 18 9"/>
              </svg>
            </summary>
            <div class="faq-item__answer">
              <p>{faq.a}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Final -->
  <section class="section" style="background: var(--forest-dark); text-align:center;">
    <div class="container">
      <h2 style="font-family:var(--font-display); font-size:clamp(1.5rem,3vw,2.2rem); color:#fff; margin-bottom:1rem;">
        ¿Listo para enviar tu resumen?
      </h2>
      <p style="color:rgba(255,255,255,0.7); margin-bottom:2rem; max-width:480px; margin-left:auto; margin-right:auto;">
        Tienes hasta el <strong style="color:var(--gold);">15 de junio de 2026</strong> para enviar tu resumen. Notificación de resultados: <strong>1 de julio de 2026</strong>. Trabajemos juntos para diseñar el futuro de la primatología en el Perú.
      </p>
      <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
        <a href="/documentos/Modelo_resumen_CPP2026.docx" download class="btn btn-lg" style="background: rgba(255,255,255,0.1); color: white; border: 1px solid rgba(255,255,255,0.2);">
          📥 Descargar Plantilla
        </a>
        <a href="https://forms.gle/Gzcr2ktTmrEnGTTh9" target="_blank" rel="noopener" class="btn btn-primary btn-lg" id="cta-enviar-resumen">
          📋 Enviar Resumen
        </a>
      </div>
    </div>
  </section>
</PageLayout>

<style>
  .call-intro { display: flex; flex-direction: column; gap: 1.5rem; max-width: 800px; margin: 0 auto; }

  .deadline-alert {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem 1.5rem;
    background: linear-gradient(135deg, rgba(201,168,76,0.12), rgba(232,201,126,0.08));
    border: 1.5px solid rgba(201,168,76,0.35);
    border-radius: var(--radius-lg);
    flex-wrap: wrap;
  }
  .deadline-alert__icon { font-size: 1.75rem; }
  .deadline-alert__text { flex: 1; font-size: 1rem; color: var(--text-on-light); }
  [data-theme="dark"] .deadline-alert__text { color: var(--text-on-dark); }
  .deadline-alert__text strong { color: var(--gold); }

  .call-desc { font-size: 0.97rem; color: var(--text-on-light); line-height: 1.8; text-align: center; }
  [data-theme="dark"] .call-desc { color: rgba(240,237,232,0.8); }

  /* Axes list */
  .axes-list { display: flex; flex-direction: column; gap: 0.75rem; max-width: 820px; margin: 0 auto; }

  .axis-row {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1.25rem 1.5rem;
    background: rgba(255,255,255,0.85);
    border-radius: var(--radius-md);
    border-left: 4px solid var(--c);
    box-shadow: var(--shadow-sm);
  }
  [data-theme="dark"] .axis-row { background: rgba(26,58,46,0.5); }

  .axis-row__emoji { font-size: 1.75rem; flex-shrink: 0; }
  .axis-row__info { display: flex; flex-direction: column; gap: 0.2rem; }
  .axis-row__code { font-family: var(--font-ui); font-size: 0.7rem; font-weight: 700; letter-spacing: 0.08em; }
  .axis-row__name { font-size: 0.97rem; font-weight: 700; color: var(--text-on-light); }
  [data-theme="dark"] .axis-row__name { color: var(--text-on-dark); }
  .axis-row__desc { font-size: 0.83rem; color: var(--text-muted); line-height: 1.55; }

  /* Formats */
  .formats-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  @media (min-width: 640px) { .formats-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .formats-grid { grid-template-columns: repeat(4, 1fr); } }

  .format-card {
    position: relative;
    padding: 2rem 1.5rem;
    background: rgba(255,255,255,0.9);
    border-radius: var(--radius-lg);
    border: 1px solid rgba(82,183,136,0.12);
    box-shadow: var(--shadow-sm);
    transition: transform var(--transition-mid), box-shadow var(--transition-mid);
  }
  [data-theme="dark"] .format-card { background: rgba(26,58,46,0.5); }
  .format-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-md); }

  .format-card__icon { font-size: 2.25rem; margin-bottom: 0.75rem; }
  .format-card__badge {
    position: absolute; top: 1rem; right: 1rem;
    font-family: var(--font-ui); font-size: 0.65rem; font-weight: 700;
    padding: 0.2rem 0.6rem; border-radius: 100px;
    background: rgba(201,168,76,0.15); color: var(--gold);
    border: 1px solid rgba(201,168,76,0.3);
  }
  .format-card__name { font-weight: 700; font-size: 1rem; color: var(--text-on-light); margin-bottom: 0.4rem; }
  [data-theme="dark"] .format-card__name { color: var(--text-on-dark); }
  .format-card__time { font-family: var(--font-ui); font-size: 0.75rem; color: var(--forest-leaf); margin-bottom: 0.75rem; font-weight: 600; }
  .format-card__desc { font-size: 0.83rem; color: var(--text-muted); line-height: 1.6; }

  /* Guidelines */
  .guidelines-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  @media (min-width: 640px) { .guidelines-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .guidelines-grid { grid-template-columns: repeat(3, 1fr); } }

  .guideline-card__desc { font-size: 0.83rem; color: var(--text-muted); line-height: 1.6; }

  /* New Requirements & Structure Styles */
  .requirements-grid { margin-bottom: 3rem; }
  .requirement-box {
    background: rgba(255,255,255,0.9);
    padding: 2rem;
    border-radius: var(--radius-lg);
    border-left: 5px solid var(--forest-leaf);
    box-shadow: var(--shadow-sm);
  }
  [data-theme="dark"] .requirement-box { background: rgba(26,58,46,0.5); }
  .requirement-box h3 { font-family: var(--font-display); font-size: 1.2rem; color: var(--forest-mid); margin-bottom: 1rem; }
  [data-theme="dark"] .requirement-box h3 { color: var(--forest-canopy); }
  .requirement-box ul { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 0.75rem; }
  .requirement-box li { position: relative; padding-left: 1.5rem; font-size: 0.95rem; color: var(--text-on-light); }
  [data-theme="dark"] .requirement-box li { color: var(--text-on-dark); }
  .requirement-box li::before { content: '→'; position: absolute; left: 0; color: var(--forest-leaf); font-weight: bold; }

  .structure-section h3 { font-family: var(--font-display); font-size: 1.2rem; text-align: center; margin-bottom: 0.5rem; color: var(--forest-mid); }
  [data-theme="dark"] .structure-section h3 { color: var(--forest-canopy); }
  .structure-section > p { text-align: center; color: var(--text-muted); margin-bottom: 2rem; font-size: 0.9rem; }
  .structure-grid { display: grid; grid-template-columns: 1fr; gap: 1.5rem; }
  @media (min-width: 768px) { .structure-grid { grid-template-columns: repeat(2, 1fr); } }
  .structure-card {
    background: rgba(255,255,255,0.8);
    padding: 1.5rem;
    border-radius: var(--radius-md);
    border: 1px solid rgba(82,183,136,0.2);
  }
  [data-theme="dark"] .structure-card { background: rgba(26,58,46,0.3); }
  .structure-card h4 { font-weight: 700; font-size: 1rem; margin-bottom: 0.5rem; color: var(--forest-leaf); }
  .structure-card p { font-size: 0.88rem; color: var(--text-muted); line-height: 1.6; }

  /* Policy table */
  .policy-table {
    max-width: 900px;
    margin: 0 auto;
    overflow-x: auto;
