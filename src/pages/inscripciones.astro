---
import PageLayout from '../layouts/PageLayout.astro';
import pricing from '../data/pricing.json';
---

<PageLayout
  title="Inscripciones"
  description="Información sobre categorías, precios, becas y proceso de inscripción al III Congreso Peruano de Primatología 2026."
  heroTitle="Inscripciones"
  heroSubtitle="Regístrate en el III Congreso Peruano de Primatología 2026"
  heroColor="var(--earth-mid)"
>
  <!-- Early Bird Alert -->
  <section class="section">
    <div class="container">
      <div class="early-bird-alert reveal">
        <div class="early-bird-alert__icon">⏰</div>
        <div>
          <strong>Inscripciones Early Bird</strong> — Disponibles hasta el 31 de mayo de 2026. ¡Asegura tu participación con el mejor precio!
        </div>
      </div>

      <!-- Pricing Table -->
      <div class="pricing-table-wrapper reveal">
        <table class="pricing-table">
          <thead>
            <tr>
              <th rowspan="2">Categoría</th>
              <th colspan="2">Early Bird <br /><small>(hasta 31 mayo)</small></th>
              <th colspan="2">Regular <br /><small>(hasta 15 julio)</small></th>
              <th colspan="2">En sede <br /><small>(Durante el congreso)</small></th>
            </tr>
            <tr>
              <th>Miembro de la Asociación Peruana de Primatología</th>
              <th>Asistente general</th>
              <th>Miembro de la Asociación Peruana de Primatología</th>
              <th>Asistente general</th>
              <th>Miembro de la Asociación Peruana de Primatología</th>
              <th>Asistente general</th>
            </tr>
          </thead>
          <tbody>
            {pricing.map((plan) => (
              <tr>
                <td><strong>{plan.category}</strong></td>
                <td class="price-val">S/ {plan.prices.early.app}</td>
                <td class="price-val">S/ {plan.prices.early.noApp}</td>
                <td class="price-val">S/ {plan.prices.regular.app}</td>
                <td class="price-val">S/ {plan.prices.regular.noApp}</td>
                <td class="price-val">S/ {plan.prices.onsite.app}</td>
                <td class="price-val">S/ {plan.prices.onsite.noApp}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <div class="discount-callout reveal">
        <div class="discount-callout__icon">👥</div>
        <div class="discount-callout__content">
          <h3>Inscripción Grupal</h3>
          <p>Obtén un <strong>20% de descuento</strong> adicional por grupos de <strong>3 personas o más</strong>. Para validar el descuento, se debe adjuntar el voucher con los nombres de todos los miembros del grupo.</p>
        </div>
        <a href="mailto:primatesperuapp@gmail.com" class="btn btn-primary">Solicitar descuento</a>
      </div>
    </div>
  </section>

  <!-- Payment Info -->
  <section class="section" id="pago">
    <div class="container">
      <div class="section-header reveal">
        <span class="section-label">Registro</span>
        <h2 class="section-title">Información de Pago</h2>
      </div>

      <div class="payment-grid">
        <!-- Bank Details Card -->
        <div class="payment-card reveal">
          <div class="payment-card__header">
            <div class="payment-card__icon">🏦</div>
            <h3 class="payment-card__title">Datos Bancarios</h3>
          </div>
          <div class="payment-card__body">
            <ul class="bank-details">
              <li><span>Titular:</span> <strong>Estación Biológica Kawsay</strong></li>
              <li><span>RUC:</span> <strong>20607343609</strong></li>
              <li><span>Banco:</span> <strong>Banco Interbank</strong></li>
              <li><span>Tipo de cuenta:</span> <strong>Cuenta Corriente Soles</strong></li>
              <li><span>Cuenta:</span> <strong>335-3003392978</strong></li>
              <li><span>CCI:</span> <strong>003-335-003003392978-74</strong></li>
              <li><span>Yape:</span> <strong>966 381 468 — Raúl Bello</strong></li>
              <li><span>Plin:</span> <strong>966 381 468 — Estación Biológica Kawsay</strong></li>
            </ul>
          </div>
        </div>

        <!-- Steps Card -->
        <div class="payment-card reveal reveal-delay-2">
          <div class="payment-card__header">
            <div class="payment-card__icon">📝</div>
            <h3 class="payment-card__title">Pasos para registrar tu pago</h3>
          </div>
          <div class="payment-card__body">
            <ol class="payment-steps">
              <li>
                <strong>Realiza la transferencia o depósito:</strong> 
                Guarda una imagen legible de tu comprobante (voucher) donde se vea claramente el monto, fecha y número de operación.
              </li>
              <li>
                <strong>Completa el formulario:</strong> 
                Ingresa tus datos en el enlace de registro de pago que encontrarás debajo.
              </li>
              <li>
                <strong>Ten tus datos a la mano:</strong> 
                Se solicitará tu número de DNI, Pasaporte o Carné de Extranjería.
              </li>
            </ol>
            
            <div class="invoice-info">
              <h4>¿Necesitas factura?</h4>
              <p>Si requieres factura institucional, deberás indicar el <strong>RUC (11 dígitos)</strong> y la <strong>Razón Social exacta</strong> en el formulario. De lo contrario, se emitirá boleta personal.</p>
            </div>
          </div>
        </div>
      </div>

      <div class="reveal" style="text-align:center; margin-top:3rem;">
        <a href="https://forms.gle/nTKgiQEpBX1GJtc19" target="_blank" rel="noopener" class="btn btn-primary btn-lg" id="cta-registro-pago">
          📋 Registrar mi Pago ahora →
        </a>
      </div>
    </div>
  </section>

  <!-- Becas -->
  <section class="section" style="background: var(--cream-warm);">
    <div class="container">
      <div class="section-header reveal">
        <span class="section-label">Apoyo económico</span>
        <h2 class="section-title">Programa de Becas</h2>
      </div>

      <div class="scholarships-grid">
        {[
          { icon: "✈️", title: "Fondo de Becas (Travel Grants)", desc: "Apoyo financiero para traslados y estadía, impulsado por aliados estratégicos. Prioriza a investigadores y líderes comunitarios de regiones Amazónicas y Andinas.", req: "Carta de motivación + Aval de organización local", deadline: "15 junio 2026" },
          { icon: "📡", title: "Nodos Descentralizados (Hubs Híbridos)", desc: "Para mitigar barreras geográficas, estableceremos centros de transmisión interactiva en Iquitos, Pucallpa y Puerto Maldonado para participación sin costo de viaje.", req: "Inscripción en formato Híbrido-Regional", deadline: "30 junio 2026" },
          { icon: "🗣️", title: "Inclusión Lingüística Estructural", desc: "Apoyo técnico para asegurar que presentaciones y resúmenes en lenguas originarias cuenten con la traducción y el soporte adecuado en el evento.", req: "Indicar requerimiento en formulario", deadline: "15 junio 2026" },
        ].map((b, i) => (
          <div class={`scholarship-card reveal reveal-delay-${i+1}`}>
            <div class="scholarship-card__icon">{b.icon}</div>
            <h3 class="scholarship-card__title">{b.title}</h3>
            <p class="scholarship-card__desc">{b.desc}</p>
            <div class="scholarship-card__req">
              <strong>Requisitos:</strong> {b.req}
            </div>
            <div class="scholarship-card__deadline">
              📅 Postular hasta: <strong>{b.deadline}</strong>
            </div>
          </div>
        ))}
      </div>

      <div class="reveal" style="text-align:center; margin-top:2rem;">
        <a href="https://forms.google.com" target="_blank" rel="noopener" class="btn btn-primary" id="cta-becas">
          Postular a una beca →
        </a>
      </div>
    </div>
  </section>

  <!-- Política de cancelación -->
  <section class="section">
    <div class="container">
      <div class="section-header reveal">
        <span class="section-label">Términos y condiciones</span>
        <h2 class="section-title">Política de Cancelación</h2>
      </div>

      <div class="policy-table reveal">
        <table>
          <thead>
            <tr>
              <th>Fecha de cancelación</th>
              <th>Reembolso</th>
            </tr>
          </thead>
          <tbody>
            <tr><td>Más de 60 días antes del congreso</td><td class="policy-green">100% reembolso</td></tr>
            <tr><td>30–60 días antes</td><td class="policy-gold">75% reembolso</td></tr>
            <tr><td>15–29 días antes</td><td class="policy-warn">50% reembolso</td></tr>
            <tr><td>Menos de 15 días o no presentación</td><td class="policy-red">Sin reembolso</td></tr>
          </tbody>
        </table>
        <p class="policy-note">* Las cancelaciones deben notificarse por escrito al correo oficial del congreso. El nombre del inscrito puede transferirse a otro participante sin cargo adicional antes de la fecha límite de inscripción.</p>
      </div>
    </div>
  </section>
</PageLayout>

<style>
  .early-bird-alert {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem 1.5rem;
    background: linear-gradient(135deg, rgba(201,168,76,0.1), rgba(232,201,126,0.07));
    border: 1.5px solid rgba(201,168,76,0.3);
    border-radius: var(--radius-md);
    font-size: 0.95rem;
    color: var(--text-on-light);
    margin-bottom: 2.5rem;
  }
  [data-theme="dark"] .early-bird-alert { color: var(--text-on-dark); }
  .early-bird-alert__icon { font-size: 1.75rem; flex-shrink: 0; }
  .early-bird-alert strong { color: var(--gold); }

  /* Pricing */
  .pricing-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    align-items: start;
  }
  @media (min-width: 768px) { .pricing-grid { grid-template-columns: repeat(3, 1fr); } }

  .pricing-card {
    position: relative;
    padding: 2rem;
    background: rgba(255,255,255,0.9);
    border-radius: var(--radius-lg);
    border: 1.5px solid rgba(82,183,136,0.15);
    box-shadow: var(--shadow-sm);
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    transition: all var(--transition-mid);
  }
  [data-theme="dark"] .pricing-card {
    background: rgba(26,58,46,0.55);
    border-color: rgba(82,183,136,0.2);
  }
  .pricing-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-md); }

  .pricing-card--featured {
    border-color: var(--forest-leaf);
    box-shadow: var(--shadow-md), 0 0 30px rgba(82,183,136,0.12);
  }

  .pricing-card__featured-badge {
    position: absolute;
    top: -13px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--forest-leaf);
    color: #fff;
    font-family: var(--font-ui);
    font-size: 0.72rem;
    font-weight: 700;
    padding: 0.3rem 1rem;
    border-radius: 100px;
    white-space: nowrap;
  }

  .pricing-card__category {
    font-family: var(--font-display);
    font-size: 1.2rem;
    color: var(--forest-mid);
  }
  [data-theme="dark"] .pricing-card__category { color: var(--forest-canopy); }
  .pricing-card__desc { font-size: 0.82rem; color: var(--text-muted); margin-top: 0.2rem; }

  .pricing-card__prices { display: flex; flex-direction: column; gap: 0.5rem; }
  .pricing-card__price { display: flex; align-items: baseline; gap: 0.5rem; flex-wrap: wrap; }
  .pricing-card__price-label { font-family: var(--font-ui); font-size: 0.72rem; font-weight: 600; color: var(--text-muted); min-width: 70px; }
  .pricing-card__price-amount { font-family: var(--font-display); font-size: 1.3rem; font-weight: 700; color: var(--text-on-light); }
  [data-theme="dark"] .pricing-card__price-amount { color: var(--text-on-dark); }
  .pricing-card__price--early .pricing-card__price-amount { color: var(--forest-leaf); font-size: 1.7rem; }
  .pricing-card__price-regular { font-size: 1rem; color: var(--text-muted); }
  .pricing-card__price-period { font-size: 0.7rem; color: var(--text-muted); }

  .pricing-card__includes {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    border-top: 1px solid rgba(82,183,136,0.1);
    padding-top: 1rem;
  }
  .pricing-card__includes li {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.82rem;
    color: var(--text-muted);
  }
  .pricing-card__includes svg { color: var(--forest-leaf); flex-shrink: 0; }

  /* Pricing Table */
  .pricing-table-wrapper {
    overflow-x: auto;
    background: rgba(255,255,255,0.9);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
    margin-bottom: 2rem;
  }
  [data-theme="dark"] .pricing-table-wrapper { background: rgba(26,58,46,0.5); }

  .pricing-table {
    width: 100%;
    border-collapse: collapse;
    min-width: 800px;
  }
  .pricing-table th, .pricing-table td {
    padding: 1.25rem 1rem;
    text-align: center;
    border: 1px solid rgba(82,183,136,0.15);
    font-size: 0.9rem;
  }
  .pricing-table th {
    background: var(--forest-mid);
    color: #fff;
    font-family: var(--font-ui);
    font-weight: 600;
  }
  .pricing-table th small { font-weight: 400; opacity: 0.9; display: block; margin-top: 0.2rem; }
  .pricing-table td:first-child { text-align: left; background: rgba(82,183,136,0.05); width: 30%; }
  .price-val { font-family: var(--font-display); font-weight: 700; color: var(--text-on-light); }
  [data-theme="dark"] .price-val { color: var(--text-on-dark); }
  .pricing-table tr:hover td { background: rgba(82,183,136,0.08); }

  /* Discount Callout */
  .discount-callout {
    display: flex;
    align-items: center;
    gap: 2rem;
    padding: 2rem;
    background: var(--forest-soft);
    border-radius: var(--radius-lg);
    border: 2px dashed var(--forest-leaf);
    margin-top: 3rem;
  }
  [data-theme="dark"] .discount-callout { background: rgba(26,58,46,0.4); }
  .discount-callout__icon { font-size: 3rem; }
  .discount-callout__content { flex: 1; }
  .discount-callout__content h3 { font-family: var(--font-display); color: var(--forest-mid); margin-bottom: 0.5rem; }
  .discount-callout__content p { font-size: 1rem; color: var(--text-on-light); }
  @media (max-width: 768px) {
    .discount-callout { flex-direction: column; text-align: center; gap: 1rem; }
  }

  /* Payment Section */
  .payment-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    margin-top: 2rem;
  }
  @media (min-width: 1024px) {
    .payment-grid { grid-template-columns: 1fr 1.2fr; }
  }

  .payment-card {
    background: rgba(255,255,255,0.9);
    border-radius: var(--radius-xl);
    border: 1px solid rgba(82,183,136,0.15);
    box-shadow: var(--shadow-md);
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
  [data-theme="dark"] .payment-card { background: rgba(26,58,46,0.55); }

  .payment-card__header {
    padding: 1.5rem 2rem;
    background: rgba(82,183,136,0.05);
    display: flex;
    align-items: center;
    gap: 1rem;
    border-bottom: 1px solid rgba(82,183,136,0.1);
  }
  .payment-card__icon { font-size: 2rem; }
  .payment-card__title { font-family: var(--font-display); font-size: 1.2rem; color: var(--forest-mid); }
  [data-theme="dark"] .payment-card__title { color: var(--forest-canopy); }

  .payment-card__body { padding: 2rem; }

  .bank-details { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 0.75rem; }
  .bank-details li { font-size: 0.95rem; display: flex; justify-content: space-between; gap: 1rem; flex-wrap: wrap; border-bottom: 1px solid rgba(82,183,136,0.05); padding-bottom: 0.5rem; }
  .bank-details span { color: var(--text-muted); font-family: var(--font-ui); font-size: 0.75rem; text-transform: uppercase; font-weight: 700; }
  .bank-details strong { color: var(--text-on-light); }
  [data-theme="dark"] .bank-details strong { color: var(--text-on-dark); }

  .payment-steps { padding-left: 1.2rem; display: flex; flex-direction: column; gap: 1.25rem; }
  .payment-steps li { font-size: 0.95rem; color: var(--text-on-light); line-height: 1.6; }
  [data-theme="dark"] .payment-steps li { color: var(--text-on-dark); }
  .payment-steps strong { color: var(--forest-leaf); }

  .invoice-info {
    margin-top: 2rem;
    padding: 1.25rem;
    background: rgba(201,168,76,0.08);
    border-left: 4px solid var(--gold);
    border-radius: var(--radius-sm);
  }
  .invoice-info h4 { font-family: var(--font-ui); font-size: 0.85rem; text-transform: uppercase; color: var(--gold); margin-bottom: 0.5rem; }
  .invoice-info p { font-size: 0.85rem; color: var(--text-muted); line-height: 1.5; }

  /* Scholarships */
  .scholarships-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  @media (min-width: 768px) { .scholarships-grid { grid-template-columns: repeat(3, 1fr); } }

  .scholarship-card {
    padding: 2rem;
    background: rgba(255,255,255,0.9);
    border-radius: var(--radius-lg);
    border: 1px solid rgba(82,183,136,0.12);
    box-shadow: var(--shadow-sm);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  [data-theme="dark"] .scholarship-card { background: rgba(26,58,46,0.5); }

  .scholarship-card__icon { font-size: 2.5rem; }
  .scholarship-card__title { font-weight: 700; font-size: 1rem; color: var(--text-on-light); }
  [data-theme="dark"] .scholarship-card__title { color: var(--text-on-dark); }
  .scholarship-card__desc { font-size: 0.85rem; color: var(--text-muted); line-height: 1.65; }
  .scholarship-card__req {
    font-size: 0.8rem; color: var(--text-muted); line-height: 1.55;
    padding: 0.75rem; background: rgba(82,183,136,0.06); border-radius: var(--radius-sm);
  }
  .scholarship-card__deadline {
    font-family: var(--font-ui); font-size: 0.78rem; color: var(--text-muted);
  }
  .scholarship-card__deadline strong { color: var(--gold); }

  /* Policy table */
  .policy-table {
    max-width: 680px;
    margin: 0 auto;
    overflow-x: auto;
  }
  .policy-table table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
  }
  .policy-table th {
    background: var(--forest-mid);
    color: #fff;
    padding: 0.85rem 1.25rem;
    text-align: left;
    font-family: var(--font-ui);
    font-size: 0.8rem;
    font-weight: 600;
  }
  .policy-table td {
    padding: 0.85rem 1.25rem;
    border-bottom: 1px solid rgba(82,183,136,0.1);
    color: var(--text-on-light);
    font-size: 0.87rem;
  }
  [data-theme="dark"] .policy-table td { color: var(--text-on-dark); border-color: rgba(82,183,136,0.15); }
  .policy-table tr:hover td { background: rgba(82,183,136,0.04); }

  .policy-green { color: var(--forest-leaf); font-weight: 700; }
  .policy-gold  { color: var(--gold); font-weight: 700; }
  .policy-warn  { color: #e07b54; font-weight: 700; }
  .policy-red   { color: #e05454; font-weight: 700; }

  .policy-note { font-size: 0.78rem; color: var(--text-muted); margin-top: 1rem; line-height: 1.6; }
</style>
